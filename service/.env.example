# ── POCX service environment ────────────────────────────────────────

# Public origin of this POCX deployment (used in emails, redirects,
# snippets and the docs). No trailing slash.
POCX_ORIGIN=http://localhost:3000

# HMAC key for signing POCX's own cookies (operator + gate sessions).
# REQUIRED in production. Any long random string.
POCX_SESSION_SECRET=

# SQLite file path (defaults to .data/pocx.db).
# POCX_DB_PATH=.data/pocx.db

# Resend for real email delivery (OTP codes, signed-terms PDFs).
# When unset, emails are logged to the outbound_emails table (visible in
# the dashboard's Emails tab) and OTP codes are printed to the server
# console — the whole product works offline.
RESEND_API_KEY=
# POCX_MAIL_FROM="POCX <access@yourdomain.com>"

# Inbound email (e.g. support@yourdomain → your real inbox).
# 1. Resend → Domains → enable receiving on the domain (adds an MX record:
#    send.yourdomain / MX 10 inbound.resend.com — Resend shows the exact
#    record; any address at the receiving domain is accepted).
# 2. Resend → Webhooks → add {POCX_ORIGIN}/api/inbound/resend for the
#    `email.received` event, and paste its signing secret (whsec_…) here.
# Messages are then re-sent to POCX_SUPPORT_INBOX with Reply-To set to the
# original sender. Unset = the webhook answers 501 and inbound is off.
RESEND_INBOUND_WEBHOOK_SECRET=
# POCX_SUPPORT_INBOX=pocx@haxo.com.au

# Stripe for real billing. When unset, the Upgrade button switches the
# workspace to Pro instantly in demo mode.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_PRO=
STRIPE_WEBHOOK_SECRET=
# Annual price (US$320/yr) — enables the yearly option at checkout.
STRIPE_PRICE_ID_PRO_YEARLY=
# Coupon offered when a monthly subscriber cancels (50% off, 3 months).
# STRIPE_RETENTION_COUPON_ID=pocx-retention-50

# Owner ops console (/admin): comma-separated admin emails. These accounts
# see EVERY workspace — keep the list tiny. Unset = /admin is disabled.
POCX_ADMIN_EMAILS=

# Session lifetimes (hours) — per-POC overrides live in POC settings.
# POCX_DEFAULT_SESSION_TTL_HOURS=24
# POCX_DEFAULT_IDLE_TIMEOUT_HOURS=3

# OTP validity window, minutes.
# POCX_OTP_TTL_MINUTES=10
