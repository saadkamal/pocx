# Your POCX instance origin (the service in ../../service, or your deployment).
POCX_URL=http://localhost:3000

# The PoC's key pair — copy both from the PoC's Integration tab in the
# POCX dashboard. The secret is server-side only; never expose it client-side.
POCX_PROJECT_KEY=pocx_pk_xxxxxxxxxxxxxxxx
POCX_SECRET=pocx_sk_xxxxxxxxxxxxxxxx

# Optional: stream page_view events to the POCX audit trail.
# POCX_LOG_EVENTS=true
